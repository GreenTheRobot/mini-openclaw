# 复制为本地环境变量配置，不要提交真实密钥
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_VISION_MODEL=
# 可选：为 cron / scheduler 固定 OpenClaw 使用的 Python，可指向 WSL 虚拟环境
MINI_OPENCLAW_PYTHON=
# 按当前模型官方价格填写，用于 Trace 成本估算
OPENCLAW_INPUT_USD_PER_MILLION=0
OPENCLAW_OUTPUT_USD_PER_MILLION=0
